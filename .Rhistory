niter=100
ncomp_mouse=16
ncomp_nhp=33
my_thresh = 0.5
# my_outcome = 'TBstatus'
if (my_outcome=='CxrRadiologistConclusion'){
dataset = df %>% filter(CxrRadiologistConclusion==1 | CxrRadiologistConclusion==5)
dataset$CxrRadiologistConclusion[dataset$CxrRadiologistConclusion==1]=0
dataset$CxrRadiologistConclusion[dataset$CxrRadiologistConclusion==5]=1
} else if (my_outcome=='LiquidCultureResult'){
dataset = df %>% filter(LiquidCultureResult==1 | LiquidCultureResult==2)
dataset$LiquidCultureResult = dataset$LiquidCultureResult %>% as.numeric()
dataset$LiquidCultureResult[dataset$LiquidCultureResult==1]=0
dataset$LiquidCultureResult[dataset$LiquidCultureResult==2]=1
} else if (my_outcome=='TBstatus'){
dataset = df %>% filter(TBstatus==1 | TBstatus==2)
dataset$TBstatus = dataset$TBstatus %>% as.numeric()
dataset$TBstatus[dataset$TBstatus==1]=0
dataset$TBstatus[dataset$TBstatus==2]=1
}  else if (my_outcome=='cluster'){
dataset = df %>% filter(!is.na(cluster))
# dataset = df %>% filter(cluster=='Cluster_A' | cluster=='Cluster_C')
dataset$cluster = dataset$cluster %>% as.numeric()
# dataset$cluster[dataset$cluster==1]=0
# dataset$cluster[dataset$cluster==2]=1
dataset$cluster[dataset$cluster!=3]=0
dataset$cluster[dataset$cluster==3]=1
} else if (my_outcome=='tb_group'){
dataset = df %>% filter(!is.na(tb_group))
dataset$tb_group = dataset$tb_group %>% as.numeric()
dataset$tb_group[dataset$tb_group==1]=1
dataset$tb_group[dataset$tb_group==2]=0
}
