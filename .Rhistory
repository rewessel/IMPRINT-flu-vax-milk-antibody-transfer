mynames = gsub('B_Colorado_06_2017','B_Colorado_06_2017',mynames)
mynames = gsub('A_Kansas_14_2017','A_Kansas_14_2017_H3N2',mynames)
mynames = gsub('A_Wisconsin_67_2022','A_Wisconsin_67_2022_H1N1',mynames)
mynames = gsub('A_Victoria_2570_2019','A_Victoria_2570_2019_H1N1',mynames)
mynames = gsub('A_Cambodia_e0826360_2020','A_Cambodia_e0826360_2020_H3N2',mynames)
mynames = gsub('B_Washington_02_2019','B_Washington_02_2019',mynames)
mynames = gsub('A_Wisconsin_588_2019','A_Wisconsin_588_2019_H1N1',mynames)
mynames = gsub('A_Indonesia_05_2005','A_Indonesia_05_2005_H5N1',mynames)
mynames = gsub('A_Shanghai_1_2013','A_Shanghai_1_2013_H7N9',mynames)
