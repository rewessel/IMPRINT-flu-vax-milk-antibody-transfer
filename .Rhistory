mynames = gsub('HongKong NA','HongKong_NA',mynames)
colnames(merged) = mynames
# read milk PBS corrected data
bm = read_xlsx('Milk_serology_v3.xlsx')
View(bm)
colnames(bm)[6:323] = paste0('milk-',colnames(bm)[6:323])
colnames(bm)[1] = 'Subject_ID'
# create file with cord and milk samples merged by study ID
merge_serum_milk = merge(bm[bm$Time_point==1,],merged[merged$`Serum Type`=='Cord',],by='Subject_ID')
View(merge_serum_milk)
merge_serum_milk = merge_serum_milk[,-c(324,326)]
merge_serum_milk = merge_serum_milk %>% select(!contains('EBV') & !contains('RSV') & !contains('Ebola'))
View(merge_serum_milk)
# create file with transfer ratios
maternal_serum = merged[merged$`Serum Type`=='Mother',]
View(maternal_serum)
# create file with transfer ratios
maternal_serum = merged[merged$`Serum Type`=='Mother',]
maternal_serum = maternal_serum %>% filter(maternal_serum$Subject_ID %in% bm$Subject_ID)
maternal_subset = maternal_serum %>% select(!contains('EBV') & !contains('RSV') & !contains('Ebola'))
bm_subset = bm %>% select(!contains('EBV') & !contains('RSV') & !contains('Ebola') & !contains('ADCP') & !contains('ADNP') & !contains('FcaR'))
colnames(maternal_subset) = gsub('serum-','',colnames(maternal_subset))
colnames(bm_subset) = gsub('milk-','',colnames(bm_subset))
View(bm_subset)
View(maternal_subset)
bm_subset = bm_subset[,c(1:5,5+order(colnames(bm_subset)[6:257]))]
maternal_subset = maternal_subset[,c(1:4,4+order(colnames(maternal_subset)[5:256]))]
# create file with transfer ratios
maternal_serum = merged[merged$`Serum Type`=='Mother',]
maternal_serum = maternal_serum %>% filter(maternal_serum$Subject_ID %in% bm$Subject_ID)
maternal_subset = maternal_serum %>% select(!contains('EBV') & !contains('RSV') & !contains('Ebola'))
bm_subset = bm %>% select(!contains('EBV') & !contains('RSV') & !contains('Ebola') & !contains('ADCP') & !contains('ADNP') & !contains('FcaR'))
colnames(maternal_subset) = gsub('serum-','',colnames(maternal_subset))
colnames(bm_subset) = gsub('milk-','',colnames(bm_subset))
bm_subset = bm_subset[,c(1:5,5+order(colnames(bm_subset)[6:257]))]
maternal_subset = maternal_subset[,c(1:4,4+order(colnames(maternal_subset)[5:256]))]
merge_maternal_milk = merge(bm_subset,maternal_subset,by='Subject_ID')
View(merge_maternal_milk)
merge_maternal_milk = merge_maternal_milk[,-c(258:260)]
merge_maternal_milk[,6:257]
merge_maternal_milk[,258:509]
transfer_ratio = merge_maternal_milk[,6:257]/merge_maternal_milk[,258:509]
View(transfer_ratio)
transfer_ratio[] = lapply(transfer_ratio, function(x) replace(x, is.infinite(x), 0))
transfer_ratio[] = lapply(transfer_ratio, function(x) replace(x, is.nan(x), 0))
colnames(transfer_ratio) = gsub('.x','',colnames(transfer_ratio))
transfer.ratios = read_xlsx('Milk_serum_transfer_ratios_v2.xlsx')
# ADD vax_timing_bin column to transfer.ratios DATA
